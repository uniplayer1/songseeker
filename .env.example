# ============================================================
# SongSeeker Workflow Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The workflow tools will automatically load it.
#
# Usage:
#   cp .env.example .env
#   nano .env          # edit with your settings
#   python tools/workflow.py
#
# Command-line flags always override .env values.
# ============================================================


# ---------------------------------------------------------------------------
# AI Provider Settings (for verify_music.py --verify-ai)
# ---------------------------------------------------------------------------

# Your API key for the AI provider.
# For OpenAI: get yours at https://platform.openai.com/api-keys
# For local providers (Ollama, LM Studio): this may not be needed.
OPENAI_API_KEY=

# API endpoint. Change this for non-OpenAI providers.
# OpenAI:          https://api.openai.com/v1
# Ollama:          http://localhost:11434/v1
# LM Studio:       http://localhost:1234/v1
# OpenRouter:      https://openrouter.ai/api/v1
# LocalAI:         http://localhost:8080/v1
OPENAI_API_BASE=https://api.openai.com/v1

# Model to use for verification.
# OpenAI options:   gpt-4o-mini (fast/cheap), gpt-4o (better quality)
# Ollama options:   llama3.1, mistral, phi3, etc.
AI_MODEL=gpt-4o-mini

# Number of songs to verify in a single API call.
# Batching is faster and cheaper but the model must support long contexts.
# Recommended: 10-30 for GPT-4o-mini, 5-10 for smaller local models.
AI_BATCH_SIZE=20


# ---------------------------------------------------------------------------
# Deemix Settings (for deemix_download.py)
# ---------------------------------------------------------------------------

# Your Deezer ARL cookie for downloading with deemix.
# How to get it:
#   1. Open your browser and go to https://www.deezer.com
#   2. Log into your Deezer account (free account works)
#   3. Open Developer Tools (F12)
#   4. Go to Application (Chrome) or Storage (Firefox) → Cookies → deezer.com
#   5. Find the cookie named 'arl' and copy its value
#   6. Paste it here (it's a long string, ~192 characters)
DEEMIX_ARL=


# ---------------------------------------------------------------------------
# Default Workflow Settings (optional)
# ---------------------------------------------------------------------------

# Your SongSeeker root URL (used when --base-url is not provided).
# The genre subfolder (e.g. /80s, /Schlager) is appended automatically.
# Example: if DEFAULT_BASE_URL=http://nas:8887/music and you process music/80s,
# the generated URLs will be http://nas:8887/music/80s/...
DEFAULT_BASE_URL=http://localhost:8887/music

# Default fuzzy match threshold (0.0 - 1.0).
# Lower = more lenient matching, Higher = stricter.
# If you get too many false matches, raise this to 0.6 or 0.7.
FUZZY_THRESHOLD=0.45


# ---------------------------------------------------------------------------
# Card Generator Defaults (optional)
# ---------------------------------------------------------------------------

# Path to the icon used in QR codes.
# Can be a local path or a URL.
ICON_PATH=icons/icon-96x96.png
